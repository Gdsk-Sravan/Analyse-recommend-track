# ─────────────────────────────────────────────────────────────────────────────
# Local .env for main.py — mirrors GitHub Actions secrets/vars from main.yml
# Copy this file to `.env` (same folder as main.py) and fill in real values.
# `.env` is loaded automatically by main.py via python-dotenv.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════ REQUIRED (workflow secrets) ════════════════════════════════
# Main Telegram bot (status + watchlist + summary messages)
TELEGRAM_BOT_TOKEN=<your_telegram_bot_token_here>
TELEGRAM_CHAT_ID=<your_telegram_chat_id_here>

# Groq AI key — at least key 1 is needed for AI thesis / news analysis
GROQ_API_KEY=<your_groq_api_key_here>
GROQ_API_KEY_1=
# Optional extra Groq keys for round-robin rotation
GROQ_API_KEY_2=<optional_second_groq_key>
GROQ_API_KEY_3=<optional_third_groq_key>

# ═══════════════ OPTIONAL (workflow secrets/vars) ═══════════════════════════
# Dedicated BUY channel (if empty, BUYs go to TELEGRAM_BOT_TOKEN)
BUY_BOT_TOKEN=
BUY_CHAT_ID=

# Dedicated TRACKER channel (if empty, tracker goes to TELEGRAM_BOT_TOKEN)
TRACKER_BOT_TOKEN=
TRACKER_CHAT_ID=

# Portfolio JSON — used when PORTFOLIO_SOURCE=MANUAL_ENV
# Example: [{"symbol":"RELIANCE.NS","entry":2800,"quantity":10,"stop":2650,"target1":3000,"target2":3200,"suggested_date":"2026-06-15"}]
MANUAL_PORTFOLIO_JSON=[]

# ═══════════════ NON-SECRET WORKFLOW VARS (sensible defaults) ════════════════
CAPITAL=500000
TOTAL_CAPITAL=500000

UNIVERSE_MODE=NSE_ALL
ENABLE_AI_SECOND_PASS=true
SHOW_VERBOSE_LOGS=false

PORTFOLIO_SOURCE=MANUAL_ENV
AUTO_TRACK_RECOMMENDED_BUYS=false
AUTO_CLOSE_EXIT_SIGNALS=false

# Cache / refresh knobs (false = use whatever is already cached locally)
FORCE_UNIVERSE_REFRESH=false
FORCE_FULL_CACHE_REFRESH=false
FORCE_PRICE_REFRESH=false

FULL_CACHE_REFRESH_WEEKDAY=0
UNIVERSE_REFRESH_DAYS=7
FULL_CACHE_REFRESH_DAYS=7
PRICE_CACHE_MAX_AGE_HOURS=18
INDEX_CACHE_MAX_AGE_HOURS=4
ACTIVE_HOLDING_CACHE_MAX_AGE_HOURS=8
CANDIDATE_CACHE_MAX_AGE_HOURS=18
CACHE_DAILY_TRADABLE_LIMIT=1500
CACHE_HIGH_QUALITY_LIMIT=250
CACHE_SMART_SKIP_ENABLED=true
CACHE_REQUIRE_CURRENT_DAILY_CANDLE=true
MARKET_DATA_READY_TIME_IST=18:15
NO_NEW_CANDLE_RETRY_HOURS=6
CACHE_SHOW_TOP_SKIPS=12

NEWS_FETCH_TOP_N=40
AI_NEWS_SYMBOL_LIMIT=15
NEWS_FETCH_MAX_WORKERS=10
NEWS_FETCH_TIMEOUT_SECONDS=8
NEWS_CACHE_TTL_HOURS=12
NEWS_MAX_HEADLINES_PER_SYMBOL=8

RISK_PER_TRADE_PCT=1.0
MAX_PORTFOLIO_HEAT=6.0
MAX_ACTIVE_POSITIONS=8
MAX_POSITION_PCT=20
MAX_SECTOR_EXPOSURE_PCT=30.0
MAX_SAME_SECTOR_POSITIONS=2
MAX_SAME_SECTOR_NEW_BUYS_PER_DAY=2
MIN_AVG_TRADED_VALUE=5000000
MIN_AVG_VOLUME=100000
MIN_REWARD_RISK=1.8
CORRELATION_LIMIT=0.78
TIME_EXIT_DAYS=10

AI_PROVIDER=groq
AI_ENABLED=true
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_TOP_CANDIDATE_LIMIT=20
LOG_AI_IO=true
GROQ_MODEL=llama-3.1-8b-instant

# Telegram-send gating (workflow sets this; local run = manual, so false)
SCHEDULED_RUN=false

# Tracker file name (Excel + JSON also written next to main.py)
TRACKER_FILE=tracker.json

# ═══════════════ PHASE C7e (2026-07-02) — kill switch, research knobs ═══════
# Kill-switch bounds (mirror workflow defaults). All optional — sensible
# defaults are baked into main.py + morning_check.py.
KS_MAX_CONSEC_LOSSES=3
KS_DAY_STOP_PCT=2.0
KS_WEEK_STOP_PCT=3.0
KS_DD_HALVE_PCT=5.0
KS_DD_HALT_PCT=10.0

# Trade-tracker V2 file (kill-switch state + performance stats)
TRADE_TRACKER_V2_FILE=trade_tracker.json

# Partial-exit % booked at T1 (rest trails to entry). Default 50.
PARTIAL_EXIT_PCT=50

# ═══════════════════════════════════════════════════════════════════════════
# Phase E1 (2026-07-02): PROFESSIONAL EXIT STACK — five layers
# ═══════════════════════════════════════════════════════════════════════════
# All layers are ADDITIVE and default OFF (behavior identical to legacy).
# Turn ON one at a time to compare vs. the previous baseline in the tracker.
#
# ── Layer 2 (E1a): Runner mode at T2 ──────────────────────────────────────
# When ON: at T2, instead of a full exit, book RUNNER_PARTIAL_PCT of the
# residual (post-T1) position and let the rest ride a chandelier trail
# (highest close since T2 minus RUNNER_ATR_MULT × ATR14). The runner closes
# on any of: (a) chandelier trail hit, (b) close below EMA21 for
# RUNNER_TREND_BREAK_DAYS in a row, (c) volume below 20d avg for
# RUNNER_VOL_FADE_DAYS, or (d) RUNNER_MAX_DAYS ceiling.
# Recommended first-pilot values are shown below.
RUNNER_MODE_ENABLED=false
RUNNER_PARTIAL_PCT=50
RUNNER_ATR_MULT=3.0
RUNNER_TREND_EMA=21
RUNNER_TREND_BREAK_DAYS=2
RUNNER_VOL_FADE_DAYS=3
RUNNER_MAX_DAYS=45

# ── Layer 3 (E1b): ATR trail after T1 ─────────────────────────────────────
# TRAIL_MODE=breakeven (legacy) — stop → entry at T1
# TRAIL_MODE=atr                — stop → max(entry, close − TRAIL_ATR_MULT × ATR14),
#                                 ratcheted daily. Rides trends better than flat entry.
TRAIL_MODE=breakeven
TRAIL_ATR_MULT=2.5

# ── Layer 4 (E1c): Conditional time exit ──────────────────────────────────
# TIME_EXIT_MODE=calendar (legacy) — expire at TIME_EXIT_MAX_DAYS if under T1.
# TIME_EXIT_MODE=conditional      — expire only when flat/losing AND weak momentum,
#                                    OR when stagnating in mid-return zone.
# Winners past TIME_EXIT_MAX_DAYS are allowed to keep running until
# TIME_EXIT_HARD_MAX_DAYS (safety cap).
TIME_EXIT_MODE=calendar
TIME_EXIT_MAX_DAYS=15
TIME_EXIT_HARD_MAX_DAYS=30
TIME_EXIT_MIN_WIN_PCT=5.0
TIME_EXIT_STAGNATION_DAYS=25
TIME_EXIT_STAGNATION_PCT=10.0

# ── Layer 5 (E1d): Regime-aware exit tightening ───────────────────────────
# When ON, in BEAR / STRONG_BEAR / HIGH_VOLATILITY regimes:
#   - runner mode is skipped (take T2 fully) even if RUNNER_MODE_ENABLED=true
#   - ATR trail multiplier is scaled by REGIME_TIGHTEN_FACTOR (e.g. 2.5 → 1.5)
#   - This reduces drawdowns during nasty tapes and locks profit faster.
REGIME_AWARE_EXITS=false
REGIME_TIGHTEN_FACTOR=0.6

# ═══════════════════════════════════════════════════════════════════════════
# Phase F (2026-07-02): PROFESSIONAL POLISH LAYER — 5 features
# ═══════════════════════════════════════════════════════════════════════════
# All F-series features are ADDITIVE and ENV-GATED. Defaults preserve legacy.
#
# ── F5: Runner "moonshot" scaling ─────────────────────────────────────────
# When a runner is +N% above T2 AND volume is expanding, book another slice.
# Locks profit on exceptional moves; runs at most once per position.
# Only meaningful when RUNNER_MODE_ENABLED=true.
RUNNER_SCALE_ENABLED=false
RUNNER_SCALE_TRIGGER_PCT=30
RUNNER_SCALE_BOOK_PCT=50
RUNNER_SCALE_VOL_MULT=1.2

# ── F7b: Parabolic single-day blow-off exit ───────────────────────────────
# If a runner gaps > PARABOLIC_DAY_PCT% in a single day on ≥ N× 20d volume,
# book PARABOLIC_BOOK_PCT% (typical exhaustion / distribution signal).
# Only meaningful when RUNNER_MODE_ENABLED=true.
PARABOLIC_EXIT_ENABLED=false
PARABOLIC_DAY_PCT=8.0
PARABOLIC_VOL_MULT=2.0
PARABOLIC_BOOK_PCT=50

# ── F7a / F8 / F9: Reporting-only sheets in tracker.xlsx ──────────────────
# These are pure-reporting additions (never touch trading logic).
# Default ON — set to false to skip the extra sheets/rows.
PORTFOLIO_RISK_SHEET=true
PNL_ATTRIBUTION_ROWS=true
BENCHMARK_OVERLAY=true
BENCHMARK_SYMBOL=^NSEI

# ═══════════════════════════════════════════════════════════════════════════
# Phase G (2026-07-02): PRODUCTION READINESS LAYER
# ═══════════════════════════════════════════════════════════════════════════
# All G-series features are additive, env-gated. Defaults are safe (read-only
# reporting = ON, intraday monitor = ON but non-fatal, everything else = OFF).

# ── G2: Equity curve + Sharpe/Sortino in tracker.xlsx ─────────────────────
# Adds an 'Equity Curve' sheet with cumulative capital, per-trade P&L,
# Sharpe, Sortino, and max drawdown. Includes an openpyxl LineChart.
EQUITY_CURVE_SHEET=true
# Starting capital in ₹ used for the equity curve simulation.
EQUITY_START=500000
# Fraction of equity risked per trade for the simulation (5 = 5%).
EQUITY_POSITION_PCT=5.0

# ── G3: Intraday state-change monitor ─────────────────────────────────────
# intraday_monitor.py runs every 15 min during market hours and sends a
# Telegram alert ONLY when an OPEN position crosses T1 / T2 / stop or
# triggers a parabolic-blowoff intraday. Read-only (never mutates any
# tracker). GitHub Actions cron: */15 4-10 * * 1-5
INTRADAY_MONITOR_ENABLED=true
# Dedup cache — one file, auto-resets each calendar day.
INTRADAY_STATE_FILE=intraday_state.json

# ── G4: Quarterly backtest recalibration ──────────────────────────────────
# backtest_walkforward.py can now write to a staging folder rather than the
# repo root. The scheduled workflow (.github/workflows/backtest.yml) always
# sets this to 'backtest_staging'. Manual local runs can leave it empty (".")
# to keep legacy behaviour.
BACKTEST_OUTPUT_DIR=.

# research_job: minimum sample size for any bucket/tercile to be reported.
MIN_SAMPLE_N=5

# weekly_summary_job: persistent file used for week-over-week deltas.
WEEKLY_METRICS_FILE=weekly_metrics.json

# Confidence-history file used by research_job trajectory analytics.
CONF_HISTORY_FILE=confidence_history.json

# FRESH_START — if 'true' for one run, wipes tracker.json / trade_tracker.json
# / confidence_history.json / watchlist_persist.json state before starting.
FRESH_START=false

# Timezone — IST
TZ=Asia/Kolkata
